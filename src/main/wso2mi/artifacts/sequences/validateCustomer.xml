<?xml version="1.0" encoding="UTF-8"?>
<sequence name="validateCustomer" xmlns="http://ws.apache.org/ns/synapse">
    <!-- Bridge variable to property for dataServiceCall param compatibility -->
    <property name="mobileNo" expression="${vars.mobileNo}" scope="default"/>
    <!-- Get customer by mobile number -->
    <dataServiceCall serviceName="InsuranceDataBase">
        <source type="inline"/>
        <operations type="single">
            <operation name="getClientByMobile">
                <param name="phone" expression="get-property('mobileNo')"/>
            </operation>
        </operations>
        <target type="body"/>
    </dataServiceCall>
    <!-- Check customer existence -->
    <filter xpath="${exists(payload.customers.customer)}">
        <then>
            <variable name="customerId" expression="${payload.customers.customer.customer_id}" type="STRING"/>
            <log category="INFO">
                <message>Customer found - ID: ${vars.customerId}</message>
            </log>
        </then>
        <else>
            <log category="WARN">
                <message>Mobile number not registered: ${vars.mobileNo}</message>
            </log>
            <payloadFactory media-type="json" template-type="default">
                <format>{
                    "status": "failed",
                    "message": "Please register for this service by dialing 07******** or visit the nearest branch."
                    }</format>
            </payloadFactory>
            <sequence key="sendNotificationEmail"/>
            <respond/>
        </else>
    </filter>
</sequence>
